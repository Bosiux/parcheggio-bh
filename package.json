{
  "name": "parcheggio-bh",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "install:frontend": "cd frontend && npm install",
    "install:all": "npm run install:frontend",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && flask run",
    "dev": "concurrently --names \"FLASK,REACT\" --prefix-colors \"blue,green\" \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}